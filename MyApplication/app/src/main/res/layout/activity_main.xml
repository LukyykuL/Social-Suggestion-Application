<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- app title at the top of the screen -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="VibeCheck"
        android:textSize="26sp"
        android:textStyle="bold"
        android:layout_marginBottom="6dp" />

    <!-- small instruction text under the title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enter a time in 24hr format "
        android:textSize="13sp"
        android:layout_marginBottom="12dp" />

    <!-- where you can enter time -->
    <EditText
        android:id="@+id/timeInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="14:30"
        android:inputType="time"
        android:layout_marginBottom="20dp" />

    <!-- runs the suggestion logic -->
    <Button
        android:id="@+id/suggestButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Suggest something"
        android:layout_marginBottom="10dp" />

    <!-- clears everything on screen -->
    <Button
        android:id="@+id/resetButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Clear"
        android:layout_marginBottom="24dp" />

    <!-- where the suggestion shows up after the button is pressed -->
    <TextView
        android:id="@+id/suggestionOutput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:text="" />

</LinearLayout>